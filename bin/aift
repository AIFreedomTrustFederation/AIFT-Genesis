#!/usr/bin/env bash
set -euo pipefail

AIFT_HOME="${AIFT_HOME:-$HOME/AIFT-Genesis}"
AIFT_TRUSTS="${AIFT_TRUSTS:-$HOME/AIFT-Trusts}"
TEMPLATE_DIR="$AIFT_HOME/templates/trust-seed"
AIFT_REMOTE="${AIFT_REMOTE:-https://github.com/AIFreedomTrustFederation/AIFT-Genesis.git}"

print_help() {
  cat <<'HELP'
AIFT CLI — Genesis Runtime

Usage:
  aift help
  aift install
  aift update
  aift doctor

  aift trust init "Trust Name"
  aift trust validate [path]
  aift trust list
  aift trust open [path]

  aift steward [path]
  aift atlas [path]
  aift sync [path]
  aift mission [path]
  aift economy [path]

Environment:
  AIFT_HOME     Path to the AIFT-Genesis repository. Default: ~/AIFT-Genesis
  AIFT_TRUSTS   Path where generated trusts are created. Default: ~/AIFT-Trusts
  AIFT_REMOTE   Git remote used by install/update.

Generator contract:
  The trust generator replaces only these variables:
    {{TRUST_NAME}}
    {{TRUST_SLUG}}
    {{TRUST_PURPOSE}}

  The constitutional trust genome text is preserved unless the generated trust later amends it through its own governance process.
HELP
}

fail() {
  echo "error: $*" >&2
  exit 1
}

notice() {
  echo "== $* =="
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

require_genesis_repo() {
  [ -d "$AIFT_HOME" ] || fail "AIFT_HOME does not exist: $AIFT_HOME"
  [ -d "$TEMPLATE_DIR" ] || fail "trust genome template not found: $TEMPLATE_DIR"
}

resolve_trust_path() {
  local target="${1:-$PWD}"
  if [ -d "$target" ]; then
    (cd "$target" && pwd)
    return 0
  fi
  if [ -d "$AIFT_TRUSTS/$target" ]; then
    (cd "$AIFT_TRUSTS/$target" && pwd)
    return 0
  fi
  fail "trust path does not exist: $target"
}

replace_tokens_in_file() {
  local file="$1"
  local trust_name="$2"
  local trust_slug="$3"
  local trust_purpose="$4"

  python3 - "$file" "$trust_name" "$trust_slug" "$trust_purpose" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
trust_name = sys.argv[2]
trust_slug = sys.argv[3]
trust_purpose = sys.argv[4]

text = path.read_text(encoding="utf-8")
text = text.replace("{{TRUST_NAME}}", trust_name)
text = text.replace("{{TRUST_SLUG}}", trust_slug)
text = text.replace("{{TRUST_PURPOSE}}", trust_purpose)
path.write_text(text, encoding="utf-8")
PY
}

validate_no_unreplaced_tokens() {
  local target="$1"
  if grep -R "{{TRUST_NAME}}\|{{TRUST_SLUG}}\|{{TRUST_PURPOSE}}" "$target" >/dev/null 2>&1; then
    echo "Unreplaced generator variables remain:" >&2
    grep -R -n "{{TRUST_NAME}}\|{{TRUST_SLUG}}\|{{TRUST_PURPOSE}}" "$target" >&2 || true
    exit 1
  fi
}

validate_no_placeholder_language() {
  local target="$1"
  python3 - "$target" <<'PY'
from pathlib import Path
import re
import sys

target = Path(sys.argv[1])
patterns = [
    re.compile(r"\bTODO\b"),
    re.compile(r"\bFIXME\b"),
    re.compile(r"\bXXX\b"),
    re.compile(r"<\s*(fill\s*in|insert|todo|replace)[^>]*>", re.I),
    re.compile(r"\[\s*(insert|fill\s*in|todo|replace)[^\]]*\]", re.I),
    re.compile(r"{{(?!TRUST_NAME}}|TRUST_SLUG}}|TRUST_PURPOSE}})[A-Z0-9_ -]+}}"),
]

matches = []
for path in sorted(target.rglob("*")):
    if "/.git/" in str(path):
        continue
    if not path.is_file():
        continue
    if path.suffix.lower() not in {".md", ".json", ".sh", ""}:
        continue
    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        continue
    for lineno, line in enumerate(text.splitlines(), 1):
        for pattern in patterns:
            if pattern.search(line):
                matches.append((path, lineno, line))
                break

if matches:
    print("Potential unfinished placeholder markers found:", file=sys.stderr)
    for path, lineno, line in matches:
        print(f"{path}:{lineno}: {line}", file=sys.stderr)
    sys.exit(1)
PY
}

validate_json() {
  local target="$1"
  find "$target" -name '*.json' -not -path '*/.git/*' -print0 | while IFS= read -r -d '' file; do
    python3 -m json.tool "$file" >/dev/null
  done
}

write_generated_readme() {
  local target="$1"
  local trust_name="$2"
  local trust_purpose="$3"

  cat > "$target/README.md" <<EOF
# $trust_name

$trust_purpose

This trust was generated from the AIFT Genesis trust genome.

## Start Here

Read these documents first:

1. TRUST.md
2. IDENTITY.md
3. VALUES.md
4. GOVERNANCE.md
5. AI_STEWARD.md
6. TREE_OF_LIFE.md
7. MAP.md
8. ECONOMY.md
9. FEDERATION_LINK.md
10. LOCAL_MANIFEST.json

## Default Posture

This trust begins local-first, private by default, and federation-capable by consent.

The Federation Link is disabled until a human steward intentionally enables public or shared participation through governance.

## First Steward Actions

1. Review the constitutional documents.
2. Confirm the trust purpose.
3. Keep location visibility private unless there is a clear reason to share.
4. Record the first governance decision.
5. Define the first Tree of Life branches and missions.
EOF
}

cmd_install() {
  require_command git
  require_command python3

  notice "AIFT install"

  mkdir -p "$HOME"
  if [ ! -d "$AIFT_HOME/.git" ]; then
    git clone "$AIFT_REMOTE" "$AIFT_HOME"
  fi

  cd "$AIFT_HOME"
  git checkout main
  git pull --ff-only origin main || true

  mkdir -p "${PREFIX:-$HOME/.local}/bin"
  local target="${PREFIX:-$HOME/.local}/bin/aift"
  chmod +x "$AIFT_HOME/bin/aift"
  cp -f "$AIFT_HOME/bin/aift" "$target"
  chmod +x "$target"
  hash -r || true

  echo "Installed: $target"
  echo "Run: aift doctor"
}

cmd_update() {
  require_command git
  require_genesis_repo

  notice "AIFT update"
  cd "$AIFT_HOME"

  if [ -n "$(git status --porcelain bin/aift 2>/dev/null || true)" ]; then
    echo "Local bin/aift changes detected; preserving them by stashing before update."
    git stash push -m "aift auto-stash before update" bin/aift >/dev/null || true
  fi

  git checkout main
  git pull --ff-only origin main

  if [ -n "${PREFIX:-}" ]; then
    chmod +x "$AIFT_HOME/bin/aift"
    cp -f "$AIFT_HOME/bin/aift" "$PREFIX/bin/aift"
    chmod +x "$PREFIX/bin/aift"
    hash -r || true
    echo "Updated installed CLI: $PREFIX/bin/aift"
  fi
}

cmd_doctor() {
  echo "AIFT Doctor"
  echo "AIFT_HOME:   $AIFT_HOME"
  echo "AIFT_TRUSTS: $AIFT_TRUSTS"
  echo "TEMPLATE:    $TEMPLATE_DIR"
  echo

  require_command git
  require_command python3

  git --version
  python3 --version

  require_genesis_repo

  echo
  echo "Trust genome files:"
  find "$TEMPLATE_DIR" -maxdepth 1 -type f | sort

  echo
  echo "Checking template JSON..."
  validate_json "$TEMPLATE_DIR"
  echo "OK"

  echo
  echo "Checking for unfinished placeholder markers in template..."
  validate_no_placeholder_language "$TEMPLATE_DIR"
  echo "OK"
}

cmd_trust_init() {
  require_command git
  require_command python3
  require_genesis_repo

  local trust_name="${1:-}"
  if [ -z "$trust_name" ]; then
    read -r -p "Trust name: " trust_name
  fi
  [ -n "$trust_name" ] || fail "trust name is required"

  local trust_purpose=""
  read -r -p "Trust purpose: " trust_purpose
  if [ -z "$trust_purpose" ]; then
    trust_purpose="A local-first trust generated from the AIFT Genesis constitutional genome to steward identity, values, governance, AI assistance, Tree of Life growth, Living Atlas context, economy, records, and voluntary Federation participation."
  fi

  local trust_slug
  trust_slug="$(slugify "$trust_name")"
  [ -n "$trust_slug" ] || fail "trust slug could not be generated"

  local target="$AIFT_TRUSTS/$trust_slug"
  [ ! -e "$target" ] || fail "trust already exists: $target"

  mkdir -p "$AIFT_TRUSTS"
  cp -R "$TEMPLATE_DIR" "$target"

  find "$target" -type f \( -name '*.md' -o -name '*.json' \) -print0 | while IFS= read -r -d '' file; do
    replace_tokens_in_file "$file" "$trust_name" "$trust_slug" "$trust_purpose"
  done

  write_generated_readme "$target" "$trust_name" "$trust_purpose"

  validate_no_unreplaced_tokens "$target"
  validate_no_placeholder_language "$target"
  validate_json "$target"

  (
    cd "$target"
    git init >/dev/null
    git add .
    git commit -m "Initialize trust genome: $trust_name" >/dev/null || true
  )

  echo "Trust created: $target"
  echo "Next: cd '$target' && git status"
}

cmd_trust_validate() {
  require_command git
  require_command python3

  local target
  target="$(resolve_trust_path "${1:-$PWD}")"

  local required_files=(
    "README.md"
    "TRUST.md"
    "IDENTITY.md"
    "VALUES.md"
    "GOVERNANCE.md"
    "AI_STEWARD.md"
    "TREE_OF_LIFE.md"
    "MAP.md"
    "ECONOMY.md"
    "FEDERATION_LINK.md"
    "LOCAL_MANIFEST.json"
  )

  echo "AIFT Trust Validate"
  echo "TRUST: $target"
  echo

  for f in "${required_files[@]}"; do
    [ -f "$target/$f" ] || fail "missing required file: $f"
  done
  echo "Required files: OK"

  validate_no_unreplaced_tokens "$target"
  echo "Generator variables: OK"

  validate_no_placeholder_language "$target"
  echo "Unfinished markers: OK"

  validate_json "$target"
  echo "JSON: OK"

  if [ -d "$target/.git" ]; then
    (
      cd "$target"
      if [ -n "$(git status --porcelain)" ]; then
        echo "Git working tree warning: uncommitted files exist"
        git status --short
      else
        echo "Git working tree: OK"
      fi
    )
  else
    fail "trust is not a git repository"
  fi

  echo
  echo "Trust validation passed."
}

cmd_trust_list() {
  mkdir -p "$AIFT_TRUSTS"
  find "$AIFT_TRUSTS" -mindepth 1 -maxdepth 1 -type d | sort
}

cmd_trust_open() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  echo "Trust path: $target"
  echo "Files:"
  find "$target" -maxdepth 1 -type f | sort
  echo
  echo "Start with: cd '$target' && cat README.md"
}

cmd_sync() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  cmd_trust_validate "$target"
  (
    cd "$target"
    git add .
    if [ -n "$(git status --porcelain)" ]; then
      git commit -m "Sync trust records"
      echo "Trust records committed locally."
    else
      echo "No trust changes to sync."
    fi
  )
}

cmd_steward() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  cat <<EOF
AIFT Steward Context
TRUST: $target

Before any AI steward acts, it should read in this order:
  1. TRUST.md
  2. IDENTITY.md
  3. VALUES.md
  4. GOVERNANCE.md
  5. AI_STEWARD.md
  6. LOCAL_MANIFEST.json

Current command is a Phase 2 context launcher. The future web UX will use this same contract to ground the AI steward before it drafts, edits, validates, or publishes anything.
EOF
}

cmd_atlas() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  cat <<EOF
AIFT Living Atlas
TRUST: $target

Green Zone source documents:
  - MAP.md
  - TREE_OF_LIFE.md
  - LOCAL_MANIFEST.json

Phase 2 status: local Atlas contract available.
Next implementation: local web view centered on this trust, with private-by-default location precision.
EOF
}

cmd_mission() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  mkdir -p "$target/missions"
  cat <<EOF
AIFT Mission Engine
TRUST: $target

Mission records folder ensured:
  $target/missions

Next implementation: aift mission create, list, complete, and fruit summary.
EOF
}

cmd_economy() {
  local target
  target="$(resolve_trust_path "${1:-$PWD}")"
  mkdir -p "$target/ledger"
  cat <<EOF
AIFT Economy Runtime
TRUST: $target

Ledger folder ensured:
  $target/ledger

Next implementation: contribution ledger, bounty records, lawful marketplace drafts, and public-good accounting.
EOF
}

case "${1:-help}" in
  help|-h|--help)
    print_help
    ;;
  install)
    cmd_install
    ;;
  update)
    cmd_update
    ;;
  doctor)
    cmd_doctor
    ;;
  trust)
    case "${2:-}" in
      init)
        shift 2
        cmd_trust_init "${1:-}"
        ;;
      validate)
        shift 2
        cmd_trust_validate "${1:-$PWD}"
        ;;
      list)
        cmd_trust_list
        ;;
      open)
        shift 2
        cmd_trust_open "${1:-$PWD}"
        ;;
      *)
        echo "Usage: aift trust init \"Trust Name\" | aift trust validate [path] | aift trust list | aift trust open [path]" >&2
        exit 1
        ;;
    esac
    ;;
  sync)
    shift || true
    cmd_sync "${1:-$PWD}"
    ;;
  steward)
    shift || true
    cmd_steward "${1:-$PWD}"
    ;;
  atlas)
    shift || true
    cmd_atlas "${1:-$PWD}"
    ;;
  mission)
    shift || true
    cmd_mission "${1:-$PWD}"
    ;;
  economy)
    shift || true
    cmd_economy "${1:-$PWD}"
    ;;
  *)
    echo "Unknown command: ${1:-}" >&2
    print_help
    exit 1
    ;;
esac
